		- ../framework/classes/phpstan/class.NonHtmlResponseHeaderDetectionRule.php
	tmpDir: /app/tmp/phpstan-cms
	dynamicConstantNames:
		- USE_PERSISTENT_CACHE

includes:
	- /app/vendor/phpstan/phpstan/conf/bleedingEdge.neon

services:
	-
		# Loaded through the documented PHPStan command's -a flag so package repos do not need Composer autoload metadata.
		class: NonHtmlResponseHeaderDetectionRule
		tags:
			- phpstan.rules.rule
